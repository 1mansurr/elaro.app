{
  "cli": {
    "version": ">= 7.6.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "buildConfiguration": "Debug",
        "image": "latest"
      }
    },
    "preview": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "image": "latest"
      }
    },
    "staging": {
      "developmentClient": false,
      "distribution": "internal",
      "channel": "staging",
      "ios": {
        "image": "latest"
      }
    },
    "production": {
      "developmentClient": false,
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "ios": {
        "image": "latest",
        "autoIncrement": "buildNumber"
      },
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": "versionCode"
      },
      "env": {
        "SENTRY_ORG": "elaro-7p",
        "SENTRY_PROJECT": "react-native",
        "SENTRY_AUTH_TOKEN": "@sentry_auth_token"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
